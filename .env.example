MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/?retryWrites=true&w=majority
# Service account do projeto Firebase. OBRIGATÓRIO: o backend valida os ID tokens
# do Firebase com ela. Sem uma credencial válida, as rotas autenticadas dão 401.
# Aceita JSON cru OU BASE64 do JSON. Em .env local use BASE64 — o JSON cru tem
# "\n" na private key que o dotenv/dotenvx corrompe ao ler de arquivo.
# Gerar base64:  cat service-account.json | base64 | tr -d '\n'
# Ex. (cru, p/ Vercel/env real): FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...","client_email":"...@....iam.gserviceaccount.com",...}
FIREBASE_SERVICE_ACCOUNT=
MONGODB_DB=codexa_live_projects
PROJECTS_COLLECTION=codexa_live_projects
CORS_ORIGIN=http://127.0.0.1:5173,http://localhost:5173
PORT=3001
VITE_API_URL=http://127.0.0.1:3001/api

# URL pública do front (usada no redirect após confirmar e-mail: /?verified=1|0)
APP_URL=http://127.0.0.1:5173
# URL pública da API (usada para montar o link de confirmação do e-mail)
API_PUBLIC_URL=http://127.0.0.1:3001
# Confirmação de e-mail via Brevo (API transacional)
BREVO_API_KEY=
MAIL_FROM_EMAIL=no-reply@codexa-web.online
MAIL_FROM_NAME=Codexa

# Discord — canal codexa-live-code (alerta de projeto novo E alerta de abuso)
DISCORD_PROJECTS_WEBHOOK_URL=
# Anti-automação no cadastro de projetos
PROJECT_COOLDOWN_MS=60000
ABUSE_BLOCK_THRESHOLD=5

# Discord — auto-join via OAuth ("Conectar Discord")
# Client ID e Guild ID são públicos. Client secret, bot token e state secret são
# sensíveis: se ausentes, o fluxo de conexão falha de forma limpa (nunca silencioso).
DISCORD_CLIENT_ID=1520480443395215501
DISCORD_CLIENT_SECRET=
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=1418937105769300051
# Precisa bater exatamente com a Redirect URI registrada no Portal do Discord.
DISCORD_REDIRECT_URI=http://127.0.0.1:3001/api/discord/callback
# Segredo HMAC usado para assinar o state do OAuth (proteção CSRF). Fail-closed se ausente.
DISCORD_STATE_SECRET=
# Webhook para avisar "novo membro confirmado entrou" (best-effort).
DISCORD_CONFIRMED_USERS_WEBHOOK_URL=
